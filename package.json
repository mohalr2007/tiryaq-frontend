{
  "name": "tiryaq-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\"",
    "dev": "next dev --turbopack --hostname 0.0.0.0",
    "dev:fresh": "npm run clean && next dev --turbopack --hostname 0.0.0.0",
    "dev:webpack": "next dev --webpack --hostname 0.0.0.0",
    "dev:fresh:webpack": "npm run clean && next dev --webpack --hostname 0.0.0.0",
    "dev:turbo": "next dev --turbopack --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "eslint",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/leaflet": "^1.9.21",
    "@types/pg": "^8.20.0",
    "@vis.gl/react-google-maps": "^1.8.1",
    "framer-motion": "^12.34.3",
    "groq-sdk": "^1.1.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
